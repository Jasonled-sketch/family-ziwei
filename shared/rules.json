{
  "rules_version": "1.1.0",
  "note": "S1 六維規則庫種子 50 條(02-social 定稿逐字)+個人(命宮)4 條+嚴重忌 fallback 1 條;id={dim}_{hua}_{nn};嚴重忌 trigger.stack 標疊法,palace=任一 表示不限宮位;文案以流日口吻撰寫,年/月層由渲染端 adaptText 換詞",
  "rules": [
    { "id": "事業_祿_01", "dim": "事業", "trigger": { "hua": "祿", "palace": "官祿", "stack": [] }, "level": "吉", "text": "工作有順風,想提的案、想談的事今天開口,成功率高。" },
    { "id": "事業_祿_02", "dim": "事業", "trigger": { "hua": "祿", "palace": "官祿", "stack": [] }, "level": "吉", "text": "今天適合接新單、談合作,對方容易點頭,把握上午黃金時段。" },
    { "id": "事業_權_01", "dim": "事業", "trigger": { "hua": "權", "palace": "官祿", "stack": [] }, "level": "吉", "text": "主導權在你手上,適合拍板、分工、定進度,說話有份量。" },
    { "id": "事業_權_02", "dim": "事業", "trigger": { "hua": "權", "palace": "官祿", "stack": [] }, "level": "平", "text": "衝勁強、強勢也強,開會少壓人一句,事情反而推得快。" },
    { "id": "事業_科_01", "dim": "事業", "trigger": { "hua": "科", "palace": "官祿", "stack": [] }, "level": "吉", "text": "名聲加分日,交報告、對外簡報、秀作品,容易被看見。" },
    { "id": "事業_科_02", "dim": "事業", "trigger": { "hua": "科", "palace": "官祿", "stack": [] }, "level": "平", "text": "適合整理文件、補流程、把帳面弄乾淨,先別急著衝新進度。" },
    { "id": "事業_忌_01", "dim": "事業", "trigger": { "hua": "忌", "palace": "官祿", "stack": [] }, "level": "凶", "text": "工作易卡關,重要簽約、報價先放一天;今天專做確認與收尾。" },
    { "id": "事業_忌_02", "dim": "事業", "trigger": { "hua": "忌", "palace": "官祿", "stack": [] }, "level": "凶", "text": "容易被改單、被放鴿子,重要事留書面紀錄,心情別跟著卡住。" },
    { "id": "財運_祿_01", "dim": "財運", "trigger": { "hua": "祿", "palace": "財帛", "stack": [] }, "level": "吉", "text": "財運順,該收的款主動催、該談的價今天談,有甜頭。" },
    { "id": "財運_祿_02", "dim": "財運", "trigger": { "hua": "祿", "palace": "財帛", "stack": [] }, "level": "吉", "text": "進帳運不錯,適合報價、上架、收款;但別見獵心喜亂加碼。" },
    { "id": "財運_權_01", "dim": "財運", "trigger": { "hua": "權", "palace": "財帛", "stack": [] }, "level": "吉", "text": "適合談錢、議價、調價格,你開的條件容易成立。" },
    { "id": "財運_權_02", "dim": "財運", "trigger": { "hua": "權", "palace": "財帛", "stack": [] }, "level": "平", "text": "花錢手感偏大,採購前先比價,設好上限再出手。" },
    { "id": "財運_科_01", "dim": "財運", "trigger": { "hua": "科", "palace": "財帛", "stack": [] }, "level": "吉", "text": "利對帳、報稅、整理財務文件,數字越清楚,財越站得穩。" },
    { "id": "財運_科_02", "dim": "財運", "trigger": { "hua": "科", "palace": "財帛", "stack": [] }, "level": "平", "text": "理財有小貴人指路,建議可聽,簽約投資仍要自己看過再說。" },
    { "id": "財運_忌_01", "dim": "財運", "trigger": { "hua": "忌", "palace": "財帛", "stack": [] }, "level": "凶", "text": "今日錢包看緊,大額支出緩一天,衝動購物先放購物車。" },
    { "id": "財運_忌_02", "dim": "財運", "trigger": { "hua": "忌", "palace": "財帛", "stack": [] }, "level": "凶", "text": "留意金錢糾紛:借出、代墊、加碼投資今天都先說不,帳當天記清。" },
    { "id": "外出_祿_01", "dim": "外出", "trigger": { "hua": "祿", "palace": "遷移", "stack": [] }, "level": "吉", "text": "出門有貴人,外出洽公、跑客戶比坐辦公室有收穫。" },
    { "id": "外出_祿_02", "dim": "外出", "trigger": { "hua": "祿", "palace": "遷移", "stack": [] }, "level": "吉", "text": "適合排出差、拜訪、看現場,路上遇到的人脈別放過。" },
    { "id": "外出_權_01", "dim": "外出", "trigger": { "hua": "權", "palace": "遷移", "stack": [] }, "level": "吉", "text": "在外的場子你能主導,適合外出談判、現場指揮。" },
    { "id": "外出_權_02", "dim": "外出", "trigger": { "hua": "權", "palace": "遷移", "stack": [] }, "level": "平", "text": "行程排太猛容易趕,開車別搶快,每段預留十分鐘緩衝。" },
    { "id": "外出_科_01", "dim": "外出", "trigger": { "hua": "科", "palace": "遷移", "stack": [] }, "level": "吉", "text": "出門形象加分,適合出席場合、露臉交流,名片多帶幾張。" },
    { "id": "外出_科_02", "dim": "外出", "trigger": { "hua": "科", "palace": "遷移", "stack": [] }, "level": "平", "text": "外出平順但步調偏慢,重要行程提早出門,別排太滿。" },
    { "id": "外出_忌_01", "dim": "外出", "trigger": { "hua": "忌", "palace": "遷移", "stack": [] }, "level": "凶", "text": "外出易延誤,重要行程提早出門;開車放慢、保持車距。" },
    { "id": "外出_忌_02", "dim": "外出", "trigger": { "hua": "忌", "palace": "遷移", "stack": [] }, "level": "凶", "text": "今天少跑遠路,能視訊就別奔波;騎車戴好安全帽慢慢騎。" },
    { "id": "朋友_祿_01", "dim": "朋友", "trigger": { "hua": "祿", "palace": "交友", "stack": [] }, "level": "吉", "text": "人緣旺,老朋友帶來新機會,飯局邀約可以答應。" },
    { "id": "朋友_祿_02", "dim": "朋友", "trigger": { "hua": "祿", "palace": "交友", "stack": [] }, "level": "吉", "text": "適合經營人脈,主動問候老客戶、老朋友,一句關心種善緣。" },
    { "id": "朋友_權_01", "dim": "朋友", "trigger": { "hua": "權", "palace": "交友", "stack": [] }, "level": "吉", "text": "朋友圈裡你說話有份量,適合揪團、主持、整合意見。" },
    { "id": "朋友_權_02", "dim": "朋友", "trigger": { "hua": "權", "palace": "交友", "stack": [] }, "level": "平", "text": "群組裡少當裁判,意見給一次就好,別替朋友做決定。" },
    { "id": "朋友_科_01", "dim": "朋友", "trigger": { "hua": "科", "palace": "交友", "stack": [] }, "level": "吉", "text": "有貴人朋友暗中幫你,遇到難題開口問,會有人指路。" },
    { "id": "朋友_科_02", "dim": "朋友", "trigger": { "hua": "科", "palace": "交友", "stack": [] }, "level": "平", "text": "適合修補關係,欠的道謝、道歉今天補上,體面收場。" },
    { "id": "朋友_忌_01", "dim": "朋友", "trigger": { "hua": "忌", "palace": "交友", "stack": [] }, "level": "凶", "text": "留意朋友間口舌,聽到閒話別轉傳;金錢往來今天先避開。" },
    { "id": "朋友_忌_02", "dim": "朋友", "trigger": { "hua": "忌", "palace": "交友", "stack": [] }, "level": "凶", "text": "朋友談合作要慢:交情歸交情、條件寫清楚,擔保先別答應。" },
    { "id": "健康_祿_01", "dim": "健康", "trigger": { "hua": "祿", "palace": "疾厄", "stack": [] }, "level": "吉", "text": "體力狀態佳,適合運動、約健檢;好習慣今天開始最容易。" },
    { "id": "健康_祿_02", "dim": "健康", "trigger": { "hua": "祿", "palace": "疾厄", "stack": [] }, "level": "吉", "text": "胃口好心情好,犒賞自己可以,八分飽剛好別過頭。" },
    { "id": "健康_權_01", "dim": "健康", "trigger": { "hua": "權", "palace": "疾厄", "stack": [] }, "level": "吉", "text": "精力旺盛,適合重訓、大掃除,把體力用在刀口上。" },
    { "id": "健康_權_02", "dim": "健康", "trigger": { "hua": "權", "palace": "疾厄", "stack": [] }, "level": "平", "text": "火力全開容易硬撐,肩頸腰背有訊號就停,別跟身體嗆聲。" },
    { "id": "健康_科_01", "dim": "健康", "trigger": { "hua": "科", "palace": "疾厄", "stack": [] }, "level": "吉", "text": "適合回診、諮詢、查報告,醫囑聽得進去,調養有貴人。" },
    { "id": "健康_科_02", "dim": "健康", "trigger": { "hua": "科", "palace": "疾厄", "stack": [] }, "level": "平", "text": "小毛病別拖,今天掛號剛好;保健習慣照表操課。" },
    { "id": "健康_忌_01", "dim": "健康", "trigger": { "hua": "忌", "palace": "疾厄", "stack": [] }, "level": "凶", "text": "身體易累,今晚十一點前睡、咖啡減半;不舒服就去看醫生。" },
    { "id": "健康_忌_02", "dim": "健康", "trigger": { "hua": "忌", "palace": "疾厄", "stack": [] }, "level": "凶", "text": "舊毛病易出聲,慢性藥別漏吃;動刀火、爬高多一分小心。" },
    { "id": "嚴重忌_忌_01", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "財帛", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "財務特別留意日:不簽約、不借貸、不大額刷卡,延到明天多半沒事。" },
    { "id": "嚴重忌_忌_02", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "疾厄", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "健康特別留意日:行程減半別硬撐,有異狀當天就醫,不用自己嚇自己。" },
    { "id": "嚴重忌_忌_03", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "遷移", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "出行特別留意日:遠程能改期就改期,開車慢一點、行程留白。" },
    { "id": "嚴重忌_忌_04", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "官祿", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "工作特別留意日:重大決策、簽約、談離職都先緩,今天只做例行事。" },
    { "id": "嚴重忌_忌_05", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "交友", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "人際特別留意日:不擔保、不拍板合夥、不接傳話,句句留紀錄。" },
    { "id": "嚴重忌_忌_06", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "命宮", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "情緒特別留意日:重話慢半拍再說,大決定睡一晚;累是訊號不是錯。" },
    { "id": "嚴重忌_忌_07", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "田宅", "stack": ["生年忌", "流日忌"] }, "level": "凶", "text": "家宅特別留意日:出門查門窗瓦斯,家電異音別拖修,家人口氣放軟。" },
    { "id": "嚴重忌_忌_08", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "任一", "stack": ["流月忌", "流日忌"] }, "level": "凶", "text": "本維度連環卡:這幾天同類事重複出包,先停損不加碼,月中後轉順。" },
    { "id": "嚴重忌_忌_09", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "任一", "stack": ["生年忌", "流月忌", "流日忌"] }, "level": "凶", "text": "今天是你本月最需要慢的一天:只做必要的事,其餘都可以等。" },
    { "id": "嚴重忌_忌_10", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "任一", "stack": ["流日忌沖", "生年忌"] }, "level": "凶", "text": "對面領域被牽動,相關的人事先安撫再處理,別兩頭燒。" },
    { "id": "個人_祿_01", "dim": "個人", "trigger": { "hua": "祿", "palace": "命宮", "stack": [] }, "level": "吉", "text": "今天整體順風,想做的事放膽推進一步。" },
    { "id": "個人_權_01", "dim": "個人", "trigger": { "hua": "權", "palace": "命宮", "stack": [] }, "level": "吉", "text": "今天幹勁足,適合主動出擊,語氣放軟效果更好。" },
    { "id": "個人_科_01", "dim": "個人", "trigger": { "hua": "科", "palace": "命宮", "stack": [] }, "level": "吉", "text": "今天形象加分,適合露臉、發表、見重要的人。" },
    { "id": "個人_忌_01", "dim": "個人", "trigger": { "hua": "忌", "palace": "命宮", "stack": [] }, "level": "凶", "text": "今天心緒偏緊,步調放慢,大決定睡一晚再說。" },
    { "id": "嚴重忌_忌_fallback", "dim": "嚴重忌", "trigger": { "hua": "忌", "palace": "任一", "stack": [] }, "level": "凶", "text": "忌象集中特別留意日:大事緩一緩,今天只做例行事,明天再處理。" }
  ]
}
